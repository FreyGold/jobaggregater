PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/jobaggDB?schema=public"
JWT_SECRET="change-this-to-a-real-secret-in-production"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
REDIS_URL="redis://localhost:6379"
# Or use discrete Redis Cloud settings instead of REDIS_URL:
# REDIS_HOST="redis-xxxx.crce288.eu-central-1-1.ec2.cloud.redislabs.com"
# REDIS_PORT=17106
# REDIS_USERNAME="default"
# REDIS_PASSWORD="change-me"
# REDIS_TLS=true

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_ID="price_..."
STRIPE_PRICE_ENTERPRISE_ID="price_..."

# App
FRONTEND_URL="http://localhost:3000"

# Manual scraping protection (required in production to call POST /api/sources/scrape)
SCRAPE_SECRET="change-me"
