# ─────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ENVIRONMENT (.env.local)
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and update values as needed
# This file is for LOCAL development only, not committed to git

# ─── Database ───────────────────────────────────────────
# When running services locally with docker-compose:
DATABASE_URL="postgresql://user:password@localhost:5432/jobaggDB"

# ─── Redis Cache ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT & Security ─────────────────────────────────────
JWT_SECRET="your-dev-jwt-secret-change-this-in-production"
JWT_EXPIRY="7d"

# ─── Application ────────────────────────────────────────
NODE_ENV="development"
PORT=3001
LOG_LEVEL="debug"

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:8081"

# ─── Frontend URL ───────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Stripe (Optional - for payment testing) ───────────
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_YOUR_TEST_KEY_HERE"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET_HERE"
STRIPE_PRICE_PRO_ID="price_YOUR_PRO_PRICE_ID"
STRIPE_PRICE_ENTERPRISE_ID="price_YOUR_ENTERPRISE_PRICE_ID"

# ─── Proxy (Optional - for bypassing regional blocks) ──
# PROXY_URL="http://proxy.example.com:8080"

# ─── Scraping (Optional) ────────────────────────────────
# DISABLE_DESCRIPTION_ENRICHMENT=false
# SCRAPER_TIMEOUT=30
