{
  "name": "jobaggregator",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @jobagg/api --filter @jobagg/web --filter moblie-app --parallel dev",
    "dev:api": "pnpm --filter @jobagg/api dev",
    "dev:web": "pnpm --filter @jobagg/web dev",
    "dev:mobile": "pnpm --filter moblie-app dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @jobagg/shared build",
    "build:api": "pnpm --filter @jobagg/api build",
    "build:web": "pnpm --filter @jobagg/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist node_modules .next .expo"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@expo/log-box": "55.0.12",
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
}
